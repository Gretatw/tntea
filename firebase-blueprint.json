{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "A customer order for bubble tea.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "items": { "type": "array" },
        "totalPrice": { "type": "number", "minimum": 0 },
        "status": { "type": "string", "enum": ["pending", "preparing", "completed", "cancelled"] }
      },
      "required": ["customerName", "customerPhone", "items", "totalPrice", "status"]
    }
  },
  "firestore": {
    "orders": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Collection of all customer orders"
    }
  }
}
