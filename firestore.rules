rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    
    // Any authenticated user is considered an admin (we only create admins manually)
    function isAdmin() { return isSignedIn(); }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'customerPhone', 'items', 'totalPrice', 'status', 'createdAt'])
        && data.customerName is string && data.customerName.size() > 0 && data.customerName.size() <= 50
        && data.customerPhone is string && data.customerPhone.size() > 0 && data.customerPhone.size() <= 20
        && data.items is list && data.items.size() > 0 && data.items.size() <= 50
        && data.totalPrice is number && data.totalPrice >= 0
        && data.status in ['pending', 'preparing', 'completed', 'cancelled']
        && data.createdAt is timestamp;
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /orders/{orderId} {
      allow create: if isValidOrder(incoming()) && incoming().status == 'pending' && incoming().createdAt == request.time;
      allow get: if true;
      allow list: if isAdmin();
      allow update: if isAdmin() && isValidOrder(incoming());
      allow delete: if isAdmin();
    }
  }
}
